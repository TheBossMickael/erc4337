# ─── ERC-4337 bundler ──────────────────────────────────────────────────

# Sepolia RPC (same value as contracts/.env)
SEPOLIA_RPC_URL=

# EntryPoint v0.8 on Sepolia (do not change)
ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108

# Addresses produced by the deployment (output of the deploy script).
# SMART_ACCOUNT_ADDRESS is OPTIONAL in V2: the bundler relays whatever `sender` the UserOp carries,
# so a freshly SETUP-deployed account works without restarting the bundler.
SMART_ACCOUNT_ADDRESS=0x...
PAYMASTER_ADDRESS=0x...
COUNTER_ADDRESS=0x...

# BUNDLER key (EOA): signs and pays the handleOps tx. Must hold sETH.
BUNDLER_PRIVATE_KEY=0xYOUR_BUNDLER_KEY

# DEPLOYER key (V2 SETUP / POST /deploy): deploys a user's SecretQuestionAccount. Must hold sETH.
# Optional — only needed to serve the "Create my account" flow. deployer != signer.
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_KEY

# OWNER key: LEGACY — only used by the V1 test client (bundler/src/client/sendUserOp.ts) to sign a
# UserOp. The V2 frontend does NOT use it: the signing key is derived in the browser from answers.
OWNER_PRIVATE_KEY=0xYOUR_OWNER_KEY

# JSON-RPC server port
PORT=3000
