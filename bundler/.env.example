# ─── ERC-4337 bundler ──────────────────────────────────────────────────

# Sepolia RPC (same value as contracts/.env)
SEPOLIA_RPC_URL=

# EntryPoint v0.8 on Sepolia (do not change)
ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108

# Paymaster from the V3 deployment (output of make deploy-v3). REQUIRED.
PAYMASTER_ADDRESS=0x...

# Optional/informational: the bundler relays whatever `sender` the UserOp carries, and V3 accounts
# are counterfactual (created lazily), so these are not required for it to run.
# SMART_ACCOUNT_ADDRESS=0x...
# COUNTER_ADDRESS=0x...

# BUNDLER key (EOA): signs and pays the handleOps tx. Must hold sETH.
BUNDLER_PRIVATE_KEY=0xYOUR_BUNDLER_KEY

# OWNER key: LEGACY — only used by the V1 test client (bundler/src/client/sendUserOp.ts). Not used
# by the V3 frontend (the signing key is a device passkey).
OWNER_PRIVATE_KEY=0xYOUR_OWNER_KEY

# JSON-RPC server port
PORT=3000
