# ─── Contracts deployment (Foundry) ────────────────────────────────────

# Sepolia RPC (or http://127.0.0.1:8545 for a local Anvil fork)
SEPOLIA_RPC_URL=

# EntryPoint v0.8 on Sepolia (do not change)
ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108

# DEPLOYER key: pays the deployment gas + the Paymaster deposit (also becomes the Paymaster owner).
PRIVATE_KEY=0xYOUR_DEPLOYER_KEY

# Initial Paymaster deposit on the EntryPoint, IN WEI. V3 note: the FIRST UserOp of each account
# also pays for that account's (~7 KB) deployment, so fund generously — 0.15 ether below.
PAYMASTER_DEPOSIT=150000000000000000

# Etherscan API key — used by `forge ... --verify` to publish & verify the source.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Legacy (only for the V1 script Deploy.s.sol) ───────────────────────
# V1 SmartAccount OWNER address (the EOA that signs V1 UserOps). Not used by V3 (DeployPasskey).
# OWNER_ADDRESS=0xYOUR_OWNER_ADDRESS
