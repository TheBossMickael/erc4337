# ─── Contracts deployment (Foundry) ────────────────────────────────────

# Sepolia RPC (or http://127.0.0.1:8545 for a local Anvil fork)
SEPOLIA_RPC_URL=

# EntryPoint v0.8 on Sepolia (do not change)
ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108

# DEPLOYER key (= bundler in V1): pays the deployment gas + the Paymaster deposit.
PRIVATE_KEY=0xYOUR_DEPLOYER_KEY

# V1 (Deploy.s.sol) — SmartAccount OWNER address (the one that signs the UserOps).
OWNER_ADDRESS=0xYOUR_OWNER_ADDRESS

# V2 (DeploySecretQuestion.s.sol) — SIGNER address DERIVED from the secret answers.
# Get it from the frontend derivation (deriveAddress) — deployer != signer. For the public demo
# answers ("rex","paris","inception") this is 0x6791C67E22f99Cf7D019f6e5D4009E9BDB853ACa.
SIGNER_ADDRESS=0xYOUR_DERIVED_SIGNER_ADDRESS

# Initial Paymaster deposit on the EntryPoint, IN WEI (0.05 ether below).
PAYMASTER_DEPOSIT=50000000000000000

# Etherscan API key — used by `forge ... --verify` to publish & verify the source.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
