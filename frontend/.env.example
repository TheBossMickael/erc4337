# ─── ERC-4337 V3 frontend (Vite) ───────────────────────────────────────
# Copy to frontend/.env and fill in. Every VITE_* var is shipped to the BROWSER, so NEVER put a
# private key here — in V3 the signing key is a P-256 passkey held by the device's authenticator.

# Sepolia RPC (or http://127.0.0.1:8545 for a local Anvil fork)
VITE_RPC_URL=

# Bundler base URL (JSON-RPC at /rpc). Local dev: http://localhost:3000. Hosted: leave EMPTY
# (relative -> same origin, since the bundler serves the frontend).
VITE_BUNDLER_URL=http://localhost:3000

# EntryPoint v0.8 (do not change on Sepolia)
VITE_ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108

# AccountFactory (CREATE2) — accounts deploy lazily via its initCode. From make deploy-v3.
VITE_FACTORY_ADDRESS=

# Paymaster + Counter from the V3 deployment (make deploy-v3)
VITE_PAYMASTER_ADDRESS=
VITE_COUNTER_ADDRESS=

# Block explorer base (Sepolia)
VITE_EXPLORER_URL=https://sepolia.etherscan.io

# NOTE: WebAuthn requires a SECURE CONTEXT. Test against the deployed HTTPS URL (Render), not a
# bare-IP/http origin. localhost is a secure context but passkey rpId is tied to the domain.
