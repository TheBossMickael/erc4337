# Frontend env for a PRODUCTION build (`npm run build`).
# Used for the local single-port test, and as a reference for the Render dashboard variables.
#   - Local test: copy this to `frontend/.env.production` and fill VITE_RPC_URL.
#   - Render: set these in the dashboard instead (do NOT commit real values).

# Relative bundler URL: in production the bundler serves the front on the SAME origin (no CORS),
# so the front calls /rpc and /deploy on the current host. Leave EMPTY.
VITE_BUNDLER_URL=

# Sepolia RPC for the browser's read calls (getUserOpHash, getNonce, count). PUBLIC in the bundle.
VITE_RPC_URL=

# Deployed V2 contracts (public)
VITE_ENTRYPOINT_ADDRESS=0x4337084d9e255ff0702461cf8895ce9e3b5ff108
VITE_DEMO_ACCOUNT_ADDRESS=0xE4c8C009A84E1d279fd5b0e4fB597374d332324C
VITE_PAYMASTER_ADDRESS=0x73B4f9E64A36a82bcCbAE8c44a098446c444C57D
VITE_COUNTER_ADDRESS=0xb73D44DeaceAdCBf060A11c9f5A22AE9dccb5F1D
VITE_EXPLORER_URL=https://sepolia.etherscan.io
